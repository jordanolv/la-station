{
  "name": "la-station-app",
  "version": "1.0.0",
  "description": "A modular Discord bot",
  "author": "Jordan.olv",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias && node scripts/copy-assets.js",
    "start": "pm2 start src/index.ts --name la-station",
    "watch": "nodemon --exec node -r @swc-node/register src/index.ts",
    "dev": "node -r @swc-node/register src/index.ts",
    "grep": "curl -s http://localhost:1234/v1/models > /dev/null 2>&1 || open -a 'LM Studio'; grepai watch --status | grep -q 'running' && echo 'grepai already running' || grepai watch --background"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript",
    "modular"
  ],
  "dependencies": {
    "@discordjs/builders": "^1.6.5",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.0.1",
    "@discordjs/voice": "^0.19.0",
    "@napi-rs/canvas": "^0.1.91",
    "@resvg/resvg-js": "^2.6.2",
    "@snazzah/davey": "^0.1.7",
    "@typegoose/typegoose": "^12.17.0",
    "@types/jsonwebtoken": "^9.0.9",
    "axios": "^1.8.4",
    "chalk": "^4.1.2",
    "cloudinary": "^2.7.0",
    "concurrently": "^8.2.2",
    "cron": "^4.1.4",
    "date-fns-tz": "^3.2.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers": "^0.7.15",
    "mongoose": "^8.16.1",
    "sodium-native": "^5.0.9",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.3",
    "@types/node": "^20.17.30",
    "nodemon": "^3.0.1",
    "tsc-alias": "^1.8.15",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  }
}
